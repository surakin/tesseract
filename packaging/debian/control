Package: tesseract-matrix
Architecture: amd64 arm64
Depends:
 ${shlibs:Depends},
 ${misc:Depends},
 libqt6core6t64 (>= 6.4) | libqt6core6 (>= 6.4),
 libqt6widgets6t64 (>= 6.4) | libqt6widgets6 (>= 6.4),
 libqt6multimedia6 (>= 6.4),
 gstreamer1.0-plugins-base
Recommends:
 gstreamer1.0-plugins-good
Conflicts: tesseract-matrix-gtk
Description: Matrix chat client (Qt6)
 Tesseract is a cross-platform Matrix/chat client with end-to-end
 encryption, image packs (MSC2545), voice messages (MSC3245), replies,
 message editing, and sticker support.
 .
 This package provides the Qt6 Widgets variant and installs
 /usr/bin/tesseract-matrix; it conflicts with tesseract-matrix-gtk.

