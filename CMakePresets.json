{
  "version": 6,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "windows-debug",
      "displayName": "Windows – Win32 (Debug)",
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
      "cacheVariables": {
        "TESSERACT_UI": "win32"
      }
    },
    {
      "name": "mingw-debug",
      "displayName": "MinGW – Win32 cross-compile from Linux (Debug)",
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
      "toolchainFile": "${sourceDir}/cmake/toolchains/mingw-x86_64.cmake",
      "cacheVariables": {
        "TESSERACT_UI": "win32",
        "Rust_CARGO_TARGET": "x86_64-pc-windows-gnu"
      }
    },
    {
      "name": "mingw-release",
      "displayName": "MinGW – Win32 cross-compile from Linux (Release)",
      "inherits": "mingw-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-release",
      "displayName": "Windows – Win32 (Release)",
      "inherits": "windows-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-debug",
      "displayName": "Linux – GTK4 + Qt6 (Debug)",
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
      "cacheVariables": {
        "TESSERACT_UI": "linux"
      }
    },
    {
      "name": "linux-release",
      "displayName": "Linux – GTK4 + Qt6 (Release)",
      "inherits": "linux-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "macos-appkit-arm64-debug",
      "displayName": "macOS – AppKit arm64 (Debug)",
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" },
      "cacheVariables": {
        "TESSERACT_UI": "macos",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "Rust_CARGO_TARGET": "aarch64-apple-darwin"
      }
    },
    {
      "name": "macos-appkit-arm64-release",
      "displayName": "macOS – AppKit arm64 (Release)",
      "inherits": "macos-appkit-arm64-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "macos-appkit-x86_64-debug",
      "displayName": "macOS – AppKit x86_64 (Debug)",
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" },
      "cacheVariables": {
        "TESSERACT_UI": "macos",
        "CMAKE_OSX_ARCHITECTURES": "x86_64",
        "Rust_CARGO_TARGET": "x86_64-apple-darwin"
      }
    },
    {
      "name": "macos-appkit-x86_64-release",
      "displayName": "macOS – AppKit x86_64 (Release)",
      "inherits": "macos-appkit-x86_64-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    { "name": "windows-debug",              "configurePreset": "windows-debug"              },
    { "name": "windows-release",            "configurePreset": "windows-release"            },
    { "name": "mingw-debug",                "configurePreset": "mingw-debug"                },
    { "name": "mingw-release",              "configurePreset": "mingw-release"              },
    { "name": "linux-debug",                "configurePreset": "linux-debug"                },
    { "name": "linux-release",              "configurePreset": "linux-release"              },
    { "name": "macos-appkit-arm64-debug",   "configurePreset": "macos-appkit-arm64-debug"   },
    { "name": "macos-appkit-arm64-release", "configurePreset": "macos-appkit-arm64-release" },
    { "name": "macos-appkit-x86_64-debug",  "configurePreset": "macos-appkit-x86_64-debug"  },
    { "name": "macos-appkit-x86_64-release","configurePreset": "macos-appkit-x86_64-release"}
  ]
}
