<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Identity -->
    <key>CFBundleName</key>             <string>Tesseract</string>
    <key>CFBundleDisplayName</key>      <string>Tesseract</string>
    <key>CFBundleIdentifier</key>       <string>im.gnomos.tesseract</string>
    <key>CFBundleVersion</key>          <string>@PROJECT_VERSION@</string>
    <key>CFBundleShortVersionString</key><string>@PROJECT_VERSION@</string>
    <key>CFBundlePackageType</key>      <string>APPL</string>
    <key>CFBundleSignature</key>        <string>????</string>
    <key>CFBundleExecutable</key>       <string>Tesseract</string>
    <key>CFBundleIconFile</key>         <string>Tesseract</string>

    <!-- AppKit principal class. With NSPrincipalClass set, calling
         NSApplicationMain() in main.mm is sufficient — no nib required. -->
    <key>NSPrincipalClass</key>         <string>NSApplication</string>

    <key>LSMinimumSystemVersion</key>   <string>11.0</string>

    <!-- Display niceties. -->
    <key>NSHighResolutionCapable</key>  <true/>
    <key>NSSupportsAutomaticGraphicsSwitching</key><true/>
    <key>NSHumanReadableCopyright</key> <string>Copyright © 2026 Marco Alvarez</string>

    <!-- Microphone and camera permissions for voice messages and calls. -->
    <key>NSMicrophoneUsageDescription</key><string>Tesseract needs microphone access to record voice messages and participate in calls.</string>
    <key>NSCameraUsageDescription</key><string>Tesseract needs camera access for video calls.</string>

    <!-- Prevent LaunchServices from opening a second instance via Finder/Dock. -->
    <key>LSMultipleInstancesProhibited</key><true/>

    <!-- matrix: URI scheme handler (MSC2312). -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeRole</key><string>Viewer</string>
            <key>CFBundleURLName</key><string>Matrix URI</string>
            <key>CFBundleURLSchemes</key>
            <array><string>matrix</string></array>
        </dict>
    </array>
</dict>
</plist>
