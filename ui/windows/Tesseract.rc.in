// Generated from Tesseract.rc.in by CMake. Do not edit the configured copy
// in the build directory — edit the .in template instead.
#include "@CMAKE_CURRENT_SOURCE_DIR@/src/resource.h"

// Lowest-numbered ICON resource also becomes the executable's shell icon
// (Explorer, taskbar, Alt+Tab) — keep IDI_TESSERACT first.
IDI_TESSERACT ICON "@TESSERACT_ICO_PATH@"

IDR_EMOJI_FONT RCDATA "@CMAKE_CURRENT_SOURCE_DIR@/fonts/NotoColorEmoji.ttf"

// App-icon PNG, materialised to disk at startup so the toast notification
// AppUserModelId IconUri can point at a real image file.
IDR_TOAST_ICON RCDATA "@CMAKE_CURRENT_SOURCE_DIR@/../icons/tesseract_160.png"

1 RT_MANIFEST "@CMAKE_CURRENT_SOURCE_DIR@/Tesseract.manifest"
