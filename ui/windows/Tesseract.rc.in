#include "@CMAKE_CURRENT_SOURCE_DIR@/src/resource.h"

// Lowest-numbered ICON resource also becomes the executable's shell icon
// (Explorer, taskbar, Alt+Tab) — keep IDI_TESSERACT first.
IDI_TESSERACT ICON "@TESSERACT_ICO_PATH@"

IDR_EMOJI_FONT RCDATA "@CMAKE_CURRENT_SOURCE_DIR@/fonts/NotoColorEmoji.ttf"
